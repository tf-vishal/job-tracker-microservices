# ─── Root .env.example ────────────────────────────────────────────────────────
# NOTE FOR LOCAL DEVELOPMENT:
# Copy this file to `.env` and it will work out of the box for `docker compose up`.
# 
# NOTE FOR DEVOPS / PRODUCTION:
# When moving to Kubernetes/AWS, you MUST change the following values to secure ones.
# ──────────────────────────────────────────────────────────────────────────────
# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── JWT (CHANGE THESE IN PRODUCTION) ──────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-min-32-chars-long
JWT_REFRESH_SECRET=super-secret-refresh-key-min-32-chars-long

# ── Internal service communication ────────────────────────────────────────────
SERVICE_API_KEY=internal-service-secret-key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# ── Notification cron (default: every hour) ───────────────────────────────────
CRON_SCHEDULE=0 * * * *

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
